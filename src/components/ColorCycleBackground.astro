---
---

<div class="bg-layer" aria-hidden="true"></div>

<aside class="readout" aria-live="polite" aria-atomic="true">
  <p><span class="label">LAB</span><span class="value" id="lab-value">L* 0.0  a* 0.0  b* 0.0</span></p>
  <p><span class="label">XYZ</span><span class="value" id="xyz-value">X 0.0  Y 0.0  Z 0.0</span></p>
  <p><span class="label">RGB</span><span class="value" id="rgb-value">rgb(0, 0, 0)</span></p>
</aside>

<script>
  const palette = [
    [16, 30, 56],
    [128, 104, 92],
    [53, 83, 118],
    [136, 132, 101],
    [28, 45, 72],
    [109, 131, 122],
    [43, 64, 97],
    [124, 136, 111],
    [67, 101, 132],
    [80, 113, 136],
    [101, 79, 92],
    [94, 124, 132]
  ];

  const root = document.documentElement;
  const rgbEl = document.getElementById('rgb-value');
  const xyzEl = document.getElementById('xyz-value');
  const labEl = document.getElementById('lab-value');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const spinDuration = reduceMotion ? 0 : 560;
  const transitionMs = reduceMotion ? 160 : 2400;
  const cycleIntervalMs = reduceMotion ? 2200 : 3000;
  const readoutDelayMs = reduceMotion ? 0 : 140;
  let currentIndex = 0;
  const lightRgb = [245, 247, 250];
  const darkRgb = [17, 19, 24];
  const onThreshold = 0.44;
  const offThreshold = 0.30;
  let prefersLightText = (() => {
    const firstLum = luminance(palette[0]);
    const firstLightContrast = contrastRatio(firstLum, luminance(lightRgb));
    const firstDarkContrast = contrastRatio(firstLum, luminance(darkRgb));
    let mode = true;
    if (mode) {
      if (firstLum >= onThreshold && firstDarkContrast >= 4.5) mode = false;
    } else if (firstLum <= offThreshold && firstLightContrast >= 4.5) {
      mode = true;
    }
    return mode;
  })();
  let cycleTimer;
  let readoutTimer;
  let rafId;
  let displayedRgb = [...palette[0]];

  function clamp(value, min, max) {
    return Math.min(max, Math.max(min, value));
  }

  function rgbToLab(rgb) {
    const lin = rgb.map((v) => {
      const c = v / 255;
      return c <= 0.04045 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
    });
    const [r, g, b] = lin;
    const X = 0.4124564 * r + 0.3575761 * g + 0.1804375 * b;
    const Y = 0.2126729 * r + 0.7151522 * g + 0.0721750 * b;
    const Z = 0.0193339 * r + 0.1191920 * g + 0.9503041 * b;
    const Xn = 0.95047, Yn = 1.00000, Zn = 1.08883;
    const e = 0.008856;
    const k = 7.787;
    const f = (t) => (t > e ? t ** (1 / 3) : k * t + 4 / 29);
    const fx = f(X / Xn), fy = f(Y / Yn), fz = f(Z / Zn);
    const L = 116 * fy - 16;
    const a = 500 * (fx - fy);
    const bStar = 200 * (fy - fz);
    return [L, a, bStar];
  }

  function rgbToXyz(rgb) {
    const lin = rgb.map((v) => {
      const c = v / 255;
      return c <= 0.04045 ? c / 12.92 : ((c + 0.055) / 1.055) ** 2.4;
    });
    const [r, g, b] = lin;
    const X = (0.4124564 * r + 0.3575761 * g + 0.1804375 * b) * 100;
    const Y = (0.2126729 * r + 0.7151522 * g + 0.0721750 * b) * 100;
    const Z = (0.0193339 * r + 0.1191920 * g + 0.9503041 * b) * 100;
    return [X, Y, Z];
  }

  function luminance(rgb) {
    const convert = (value) => {
      const v = value / 255;
      return v <= 0.03928 ? v / 12.92 : ((v + 0.055) / 1.055) ** 2.4;
    };
    const [r, g, b] = rgb.map(convert);
    return 0.2126 * r + 0.7152 * g + 0.0722 * b;
  }

  function contrastRatio(l1, l2) {
    const lighter = Math.max(l1, l2);
    const darker = Math.min(l1, l2);
    return (lighter + 0.05) / (darker + 0.05);
  }

  function setContrastVars(rgb) {
    const bgLum = luminance(rgb);
    const lightContrast = contrastRatio(bgLum, luminance(lightRgb));
    const darkContrast = contrastRatio(bgLum, luminance(darkRgb));

    if (prefersLightText) {
      if (bgLum >= onThreshold && darkContrast >= 4.5) prefersLightText = false;
    } else if (bgLum <= offThreshold && lightContrast >= 4.5) {
      prefersLightText = true;
    }

    const useLight = prefersLightText;

    root.style.setProperty('--fg', useLight ? '#F5F7FA' : '#111318');
    root.style.setProperty(
      '--fg-muted',
      useLight ? 'rgba(245, 247, 250, 0.82)' : 'rgba(17, 19, 24, 0.82)'
    );
  }

  function renderValues(rgb) {
    const [L, a, b] = rgbToLab(rgb);
    const [X, Y, Z] = rgbToXyz(rgb);
    labEl.textContent = `L* ${L.toFixed(1)}  a* ${a.toFixed(1)}  b* ${b.toFixed(1)}`;
    xyzEl.textContent = `X ${X.toFixed(1)}  Y ${Y.toFixed(1)}  Z ${Z.toFixed(1)}`;
    rgbEl.textContent = `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`;
  }

  function applyBackground(rgb) {
    root.style.setProperty('--bg-color', `rgb(${rgb[0]}, ${rgb[1]}, ${rgb[2]})`);
    setContrastVars(rgb);
  }

  function easeOutCubic(t) {
    return 1 - (1 - t) ** 3;
  }

  function spinToColor(targetRgb) {
    if (reduceMotion) {
      displayedRgb = [...targetRgb];
      renderValues(displayedRgb);
      return;
    }

    const startRgb = [...displayedRgb];
    const start = performance.now();

    const tick = (now) => {
      const progress = clamp((now - start) / spinDuration, 0, 1);
      const eased = easeOutCubic(progress);
      const wobbleAmplitude = (1 - progress) * 8;
      const wobble = [
        Math.sin(now * 0.045) * wobbleAmplitude,
        Math.sin(now * 0.055 + 1.7) * wobbleAmplitude,
        Math.sin(now * 0.05 + 3.2) * wobbleAmplitude
      ];

      const nextRgb = [0, 1, 2].map((i) =>
        Math.round(
          clamp(startRgb[i] + (targetRgb[i] - startRgb[i]) * eased + wobble[i], 0, 255)
        )
      );

      renderValues(nextRgb);

      if (progress < 1) {
        rafId = requestAnimationFrame(tick);
      } else {
        displayedRgb = [...targetRgb];
        renderValues(displayedRgb);
      }
    };

    rafId = requestAnimationFrame(tick);
  }

  function scheduleNext() {
    cycleTimer = window.setTimeout(() => {
      currentIndex = (currentIndex + 1) % palette.length;
      const next = palette[currentIndex];
      applyBackground(next);
      readoutTimer = window.setTimeout(() => {
        spinToColor(next);
      }, readoutDelayMs);
      scheduleNext();
    }, cycleIntervalMs);
  }

  applyBackground(palette[currentIndex]);
  renderValues(palette[currentIndex]);
  scheduleNext();

  window.addEventListener(
    'pagehide',
    () => {
      window.clearTimeout(cycleTimer);
      window.clearTimeout(readoutTimer);
      if (rafId) {
        cancelAnimationFrame(rafId);
      }
    },
    { once: true }
  );
</script>

<style>
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-color: var(--bg-color, rgb(16, 30, 56));
    transition: background-color 2400ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .readout {
    --target-size: 24px;
    --pointer-length: 100px;
    position: fixed;
    left: 50%;
    bottom: calc(16px + env(safe-area-inset-bottom));
    transform: translateX(-50%);
    z-index: 3;
    pointer-events: none;
    width: min(260px, calc(100vw - 32px));
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(10, 12, 18, 0.38);
    backdrop-filter: blur(6px);
    color: var(--fg, #f5f7fa);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
    font-size: 13px;
    line-height: 1.5;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
    transition: color 420ms ease, border-color 420ms ease, background-color 420ms ease;
  }

  .readout::before {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 100%;
    width: 2px;
    height: var(--pointer-length);
    transform: translateX(-50%);
    background: var(--fg-muted, rgba(245, 247, 250, 0.82));
    opacity: 0.55;
  }

  .readout::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: calc(100% + var(--pointer-length));
    width: var(--target-size);
    height: var(--target-size);
    transform: translateX(-50%);
    border: 2px solid var(--fg-muted, rgba(245, 247, 250, 0.82));
    border-radius: 5px;
    opacity: 0.72;
    background:
      linear-gradient(#FFFFFF, #FFFFFF) center / 1.5px 12px no-repeat,
      linear-gradient(90deg, #FFFFFF, #FFFFFF) center / 12px 1.5px no-repeat;
  }

  :global(body) {
    transition: color 420ms ease;
  }

  .readout p {
    margin: 0;
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr);
    align-items: baseline;
    gap: 12px;
  }

  .label {
    opacity: 0.72;
  }

  .value {
    white-space: nowrap;
    text-align: right;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-layer {
      transition-duration: 160ms;
    }
  }
</style>
